# Hepsi İSTEĞE BAĞLIDIR — hiçbiri olmadan da uygulama "şablon modu"nda çalışır.
# Ücretsiz API anahtarları:
#   Gemini     : https://aistudio.google.com/apikey   (önerilen, kredi kartı istemez)
#   Groq       : https://console.groq.com/keys
#   OpenRouter : https://openrouter.ai/keys           (":free" modeller kullanılır)
# Anahtarları web arayüzündeki "Ayarlar" panelinden de girebilirsiniz.

# GEMINI_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=

# Model geçersiz kılma (varsayılanlar genellikle yeterli)
# GEMINI_MODEL=gemini-2.0-flash
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Literatür API'leri anahtar istemez; nazik kullanım için e-posta önerilir:
# CONTACT_EMAIL=ornek@mail.com

# 1 yapılırsa literatür taraması ağa çıkmaz (test amaçlı)
# PAPERFORGE_OFFLINE=0
